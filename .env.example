# ------------------------------
# n8n
# ------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678
GENERIC_TIMEZONE=Asia/Dubai
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENCRYPTION_KEY=replace-with-32-char-random
GSHEET_ID=replace-with-google-sheet-id
GSHEET_ENABLED=false
BRIDGE_BASE_URL=http://bridge:8080
OUTREACH_SENDER_NAME=Your Name
OUTREACH_SYSTEM_PROMPT=You write concise Telegram outreach messages. Keep them human, factual, and non-pushy.
SEND_DELAY_MIN_SECONDS=180
SEND_DELAY_MAX_SECONDS=600
FOLLOWUP_MIN_DAYS=2
FOLLOWUP_MAX_DAYS=3
MAX_FOLLOWUPS=2

# ------------------------------
# Telegram bridge
# ------------------------------
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8080
BRIDGE_ENV=dev
BRIDGE_LOG_LEVEL=INFO
BRIDGE_API_KEY=replace-with-strong-api-key

# Telethon user account credentials
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace-with-real-api-hash
TELEGRAM_PHONE=+971500000000
TELEGRAM_SESSION_STRING=
SESSION_ENCRYPTION_KEY=replace-with-fernet-key
TELEGRAM_MOCK_MODE=true

# Ops + webhooks
OPS_BOT_TOKEN=replace-with-ops-bot-token
OPS_CHAT_ID=-100123456789
OPS_NOTIFY_ENABLED=false
N8N_EVENTS_WEBHOOK_URL=http://n8n:5678/webhook/telegram/events

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI (used for draft/rewrite/summary generation)
OPENAI_API_KEY=replace-with-openai-key

# Warmup + retry
DAILY_SEND_CAP=10
IDEMPOTENCY_TTL_SECONDS=604800
DELIVERY_RETRY_DELAYS=120,600,1800
APPROVAL_SLA_MINUTES=120
