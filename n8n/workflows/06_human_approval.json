            "draft_text": "={{$json.draft_text}}",
            "status": "={{$json.status}}",
            "claimed_by": "={{$json.claimed_by || $json.actor}}",
            "created_at": "={{$json.created_at}}",
            "sla_due_at": "={{$json.sla_due_at}}",
            "resolution": "={{$json.resolution}}"
          },
          "schema": []
        }
      },
      "id": "append-approval-audit",
      "name": "Append Approval Audit",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        1660,
