          "id": "REPLACE_ME",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{$env.OPS_CHAT_ID}}",
        "text": "={{'Action processed: ' + $json.action + ' for task ' + $json.task_id + ' by ' + $json.actor}}",
        "additionalFields": {
          "appendAttribution": false
        }
      },
      "id": "confirm-action",
      "name": "Confirm in Ops Group",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1900,
        320
      ],
      "credentials": {
        "telegramApi": {
          "id": "REPLACE_ME",
          "name": "Ops Telegram Bot"
        }
      }
    }
